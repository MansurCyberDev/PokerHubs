# Poker Bot Environment Configuration
# Copy this file to .env and fill in your values

# ==================== REQUIRED ====================

# Telegram Bot Token (get from @BotFather)
# Example: 123456789:ABCdefGHIjklMNOpqrSTUvwxyz
POKER_BOT_TOKEN=8633427504:AAGASNDFuoBo174hfI2HXoa72lVx228tIBs

# Admin User IDs (comma-separated list of Telegram user IDs)
# Get your ID from @userinfobot
# Example: 123456789,987654321
POKER_ADMIN_IDS=5491969475

# ==================== PAYMENT ====================

# Kaspi Pay Card Number for receiving payments
# Example: 4400430233136370
KASPI_CARD=4400430233136370

# Support Telegram username (without @)
# Example: mysupport
POKER_SUPPORT_USERNAME=golovorezsm

# ==================== GAME SETTINGS ====================
# All values have sensible defaults, uncomment to override

# Minimum players to start a game (default: 2)
# POKER_MIN_PLAYERS=2

# Maximum players per table (default: 9)
# POKER_MAX_PLAYERS=9

# Starting chips for new players (default: 1000)
# POKER_STARTING_STACK=1000

# Small blind amount (default: 10)
# POKER_SMALL_BLIND=10

# Big blind amount (default: 20)
# POKER_BIG_BLIND=20

# Registration time in seconds (default: 120)
# POKER_REGISTRATION_TIME=120

# Turn time in seconds (default: 60)
# POKER_TURN_TIME=60

# ==================== INFRASTRUCTURE (Production) ====================

# Environment: development | production
ENVIRONMENT=development

# Bot version (for tracking)
BOT_VERSION=2.0.0

# ==================== DATABASE ====================
# SQLite is default. For production with high load, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/pokerdb
DATABASE_URL=

# PostgreSQL settings (for docker-compose)
POSTGRES_PASSWORD=Mansur282348@228

# ==================== REDIS ====================
# Redis for game state and caching (recommended for production)
# REDIS_URL=redis://localhost:6379
REDIS_URL=

# ==================== SENTRY (Error Tracking) ====================
# Get DSN from https://sentry.io
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
SENTRY_DSN=

# ==================== WEBHOOK (Production) ====================
# Set to 'true' for webhook mode (recommended for production)
# Set to 'false' for polling mode (for local development)
USE_WEBHOOK=false

# Webhook URL - your domain
# Example: https://api.pokerhubs.com
WEBHOOK_URL=

# Internal port
WEBHOOK_PORT=8443

# ==================== FEATURE FLAGS ====================
# Enable/disable features (true/false)
USE_POSTGRES=false
USE_REDIS=false
ENABLE_ANTIFRAUD=true
ENABLE_RATE_LIMIT=true

# ==================== GRAFANA ====================
# Password for Grafana dashboard (default: admin)
GRAFANA_PASSWORD=admin

# ==================== BACKUP ====================
# Automatic backups run every hour
# Daily backups are kept for 7 days
# Hourly backups are kept for 24 hours

# ==================== NOTES ====================
# 1. Never commit .env file to git!
# 2. Keep your bot token and passwords secret
# 3. Test payment flow with small amounts first
# 4. Monitor logs/ directory for errors
# 5. For production: USE_WEBHOOK=true, USE_POSTGRES=true, USE_REDIS=true
